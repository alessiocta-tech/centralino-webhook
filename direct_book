{
  "type": "webhook",
  "name": "direct_book",
  "description": "Registra una prenotazione direttamente nel sistema. Verifica automaticamente la disponibilità e restituisce SOLD_OUT (HTTP 409) se il turno è pieno. Chiamare solo dopo il sì al riepilogo. Data in ISO YYYY-MM-DD (già risolta e confermata). Orario in HH:MM (orario ufficiale del turno, non quello detto dal cliente). Per più di 9 persone NON chiamare questo tool: comunicare il numero 06 56556 263.",
  "disable_interruptions": false,
  "force_pre_tool_speech": "auto",
  "tool_call_sound": null,
  "tool_call_sound_behavior": "auto",
  "tool_error_handling_mode": "auto",
  "execution_mode": "immediate",
  "api_schema": {
    "url": "https://centralino-webhook-production.up.railway.app/direct_book",
    "method": "POST",
    "path_params_schema": [],
    "query_params_schema": [],
    "request_body_schema": {
      "id": "body",
      "type": "object",
      "description": "Dati per la prenotazione diretta",
      "properties": [
        {
          "id": "nome",
          "type": "string",
          "value_type": "llm_prompt",
          "description": "Nome del cliente.",
          "dynamic_variable": "",
          "constant_value": "",
          "enum": [],
          "is_system_provided": false,
          "required": true
        },
        {
          "id": "telefono",
          "type": "string",
          "value_type": "llm_prompt",
          "description": "Numero di cellulare del cliente (solo cifre, senza spazi o simboli).",
          "dynamic_variable": "",
          "constant_value": "",
          "enum": [],
          "is_system_provided": false,
          "required": true
        },
        {
          "id": "sede",
          "type": "string",
          "value_type": "llm_prompt",
          "description": "Sede del ristorante. Valori supportati: Talenti, Appia, Ostia Lido, Reggio Calabria, Palermo, Corso Trieste.",
          "dynamic_variable": "",
          "constant_value": "",
          "enum": [
            "Talenti",
            "Appia",
            "Ostia Lido",
            "Reggio Calabria",
            "Palermo",
            "Corso Trieste"
          ],
          "is_system_provided": false,
          "required": true
        },
        {
          "id": "data",
          "type": "string",
          "value_type": "llm_prompt",
          "description": "Data prenotazione in formato YYYY-MM-DD. Deve essere già risolta tramite resolve_date e confermata dall'utente se relativa.",
          "dynamic_variable": "",
          "constant_value": "",
          "enum": [],
          "is_system_provided": false,
          "required": true
        },
        {
          "id": "orario",
          "type": "string",
          "value_type": "llm_prompt",
          "description": "Orario in formato HH:MM. In caso di doppio turno usare l'orario ufficiale di inizio turno, non l'orario detto dal cliente. Esempi: '20:00', '21:00', '19:30'.",
          "dynamic_variable": "",
          "constant_value": "",
          "enum": [],
          "is_system_provided": false,
          "required": true
        },
        {
          "id": "coperti",
          "type": "number",
          "value_type": "llm_prompt",
          "description": "Numero di persone (1–9). Se l'utente indica più di 9 persone non chiamare questo tool: comunicare il numero 06 56556 263 e terminare il flusso.",
          "dynamic_variable": "",
          "constant_value": "",
          "enum": [],
          "is_system_provided": false,
          "required": true
        },
        {
          "id": "cognome",
          "type": "string",
          "value_type": "constant",
          "description": "Cognome del cliente. Non chiedere mai all'utente. Inviare sempre 'Cliente'.",
          "dynamic_variable": "",
          "constant_value": "Cliente",
          "enum": [],
          "is_system_provided": false,
          "required": false
        },
        {
          "id": "email",
          "type": "string",
          "value_type": "llm_prompt",
          "description": "Indirizzo email del cliente. Inviare SOLO se l'utente l'ha fornita esplicitamente. Se l'utente non vuole ricevere conferme email, omettere completamente questo campo.",
          "dynamic_variable": "",
          "constant_value": "",
          "enum": [],
          "is_system_provided": false,
          "required": false
        },
        {
          "id": "seggiolini",
          "type": "number",
          "value_type": "llm_prompt",
          "description": "Numero di seggiolini (0–2). Compilare SOLO se l'utente cita bambini (bambino, bambina, bimbo, neonato, passeggino). Altrimenti omettere o inviare 0.",
          "dynamic_variable": "",
          "constant_value": "",
          "enum": [],
          "is_system_provided": false,
          "required": false
        },
        {
          "id": "nota",
          "type": "string",
          "value_type": "llm_prompt",
          "description": "Allergie, intolleranze o richieste speciali per il tavolo. Omettere se non presenti.",
          "dynamic_variable": "",
          "constant_value": "",
          "enum": [],
          "is_system_provided": false,
          "required": false
        }
      ],
      "required": false,
      "value_type": "llm_prompt"
    },
    "request_headers": [],
    "auth_connection": null
  },
  "assignments": [],
  "response_timeout_secs": 30,
  "dynamic_variables": {
    "dynamic_variable_placeholders": {}
  }
}
