{
  "type": "webhook",
  "name": "change_date",
  "description": "Modifica la data e/o l'orario di una prenotazione esistente. Cerca la prenotazione per telefono + nome (o data attuale), verifica la disponibilità alla nuova data/ora richiesta, e se disponibile annulla la vecchia e crea la nuova automaticamente. Se non disponibile restituisce SOLD_OUT. IMPORTANTE: non usare resolve_date per le date — convertire internamente (es. 'sabato 21 marzo' → '2026-03-21'). In caso di errore tecnico (502, 504) riprovare una volta in silenzio.",
  "disable_interruptions": false,
  "force_pre_tool_speech": "auto",
  "tool_call_sound": null,
  "tool_call_sound_behavior": "auto",
  "tool_error_handling_mode": "auto",
  "execution_mode": "immediate",
